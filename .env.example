# .env.example — ScannerCV
# Copie para .env e preencha os valores antes de rodar o projeto.

# === BANCO DE DADOS ===
DATABASE_URL=sqlite:///./scannercv.db
# Em produção, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@db:5432/scannercv

# === BANCO DE DADOS ===
DB_USER=scannercv_user
DB_PASSWORD=mudar_para_uma_senha_forte
DB_NAME=scannercv_db

# === OPENAI ===
OPENAI_API_KEY=sk-...           # Obrigatório para análise real (sem ela, retorna mock)
OPENAI_MODEL=gpt-4o-mini        # Modelo padrão (gpt-4o para maior qualidade)

# === AUTENTICAÇÃO ===
ADMIN_PASSWORD=                  # OBRIGATÓRIO: mínimo 6 caracteres

# === EMAIL / SMTP ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seuemail@gmail.com
SMTP_PASSWORD=sua-app-password   # App Password do Google, não a senha normal
FROM_EMAIL=seuemail@gmail.com

# === SEGURANÇA ===
ALLOWED_ORIGINS=http://localhost:5173  # Em produção: https://seusite.com.br
DAILY_SCAN_LIMIT=5

# === INTERVIEW TRAINING MODULE ===
EVOLUTION_API_URL=                     # URL da Evolution API (ex: http://localhost:8084)
EVOLUTION_API_KEY=                     # API Key da Evolution API
EVOLUTION_INSTANCE=scannercv           # Nome da instância no Evolution API
WHISPER_MODEL=whisper-1                # Modelo de transcrição (whisper-1 ou gpt-4o-mini-transcribe)
APP_BASE_URL=http://localhost:5173     # URL base do site (p/ links no WhatsApp)
