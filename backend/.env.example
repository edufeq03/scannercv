# ScannerCV Environment Variables
# Copie este arquivo para .env e preencha os valores antes de iniciar.

# --- SERVER CONFIG ---
DATABASE_URL=sqlite:///./scannercv.db
# Para PostgreSQL: DATABASE_URL=postgresql://user:password@db:5432/scannercv
ADMIN_EMAIL=admin@scannercv.com.br
ADMIN_PASSWORD=change_this_to_a_secure_password
JWT_SECRET_KEY=generate_a_random_string_here
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.com.br
DAILY_SCAN_LIMIT=5

# --- AI & EXTERNAL APIS ---
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini  # (gpt-4o-mini ou gpt-4o para maior qualidade)
EVOLUTION_API_URL=https://api.sua-evolution.com.br
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=sua-instancia
WHISPER_MODEL=whisper-1

# --- EMAIL CONFIG (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=Sistema ScannerCV <seu-email@gmail.com>

# --- URLS ---
APP_BASE_URL=http://localhost:5173
